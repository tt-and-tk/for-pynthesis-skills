      "Bash(gh api repos/*/pulls/*/comments/*/replies:*)",
      "Bash(gh api repos/*/issues/*/comments:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue create:*)",
      "Bash(claude -p:*)"
