{
  "extraKnownMarketplaces": {
    "for-pynthesis-skills": {
      "source": {
        "source": "github",
        "repo": "tt-and-tk/for-pynthesis-skills"
      }
    }
  },
  "enabledPlugins": {
    "for-pynthesis-skills@for-pynthesis-skills": true
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git pull)",
      "Bash(git branch -d:*)",
      "Bash(git branch --show-current)",
      "Bash(git branch)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
